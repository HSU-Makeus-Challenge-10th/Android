<resources xmlns:tools="http://schemas.android.com/tools">
    
    <style name="Base.Theme.Yido" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="tabStyle">@style/ShopTabLayout</item>
    </style>

    <style name="Theme.Yido" parent="Base.Theme.Yido" />

    <!-- Splash Screen 테마: 앱 시작 시 사용 -->
    <style name="Theme.Yido.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="postSplashScreenTheme">@style/Theme.Yido</item>
    </style>

    <style name="BottomNav.NoIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">0dp</item>
        <item name="android:height">0dp</item>
        <item name="android:color">@android:color/transparent</item>
    </style>

    <!-- TabLayout 하단 구분선 제거, 배경 흰색 -->
    <style name="ShopTabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/black</item>
        <item name="tabIndicatorHeight">2dp</item>
        <item name="android:background">@color/white</item>
    </style>

</resources>