<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".HomeFragment">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp">

            <TextView
                android:id="@+id/home_tv_discover"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_title"
                android:textSize="32sp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="24dp" />

            <TextView
                android:id="@+id/home_tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_date"
                android:textSize="14sp"
                android:textColor="@color/home_date_text"
                android:layout_marginTop="4dp"
                android:paddingHorizontal="24dp" />

            <ImageView
                android:id="@+id/home_iv_hero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@drawable/img_nike_hero"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="24dp"
                android:contentDescription="@string/home_title" />

            <TextView
                android:id="@+id/home_tv_whats_new"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_whats_new"
                android:textSize="13sp"
                android:textColor="@color/shop_tab_text_inactive"
                android:layout_marginTop="24dp"
                android:paddingHorizontal="24dp" />

            <TextView
                android:id="@+id/home_tv_new_products"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_new_products"
                android:textSize="20sp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:paddingHorizontal="24dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/home_rv_products"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingStart="24dp"
                android:clipToPadding="false"
                android:orientation="horizontal" />

            <View
                android:layout_width="match_parent"
                android:layout_height="200dp" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
