<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true">

    <!-- 타이틀 -->
    <TextView
        android:id="@+id/cart_tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tab_cart"
        android:textSize="28sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 중앙 빈 장바구니 아이콘 -->
    <ImageView
        android:id="@+id/cart_iv_empty"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_cart_empty"
        android:contentDescription="빈 장바구니"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cart_tv_empty_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="16dp" />

    <!-- 빈 장바구니 안내 텍스트 타이틀 -->
    <TextView
        android:id="@+id/cart_tv_empty_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="장바구니가 비어 있습니다."
        android:textSize="14sp"
        android:textColor="@color/black"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/cart_iv_empty"
        app:layout_constraintBottom_toTopOf="@id/cart_tv_empty_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="4dp" />

    <!-- 빈 장바구니 안내 텍스트 설명 -->
    <TextView
        android:id="@+id/cart_tv_empty_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="제품을 추가하면 여기에 표시됩니다."
        android:textSize="13sp"
        android:textColor="@color/black"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/cart_tv_empty_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 주문하기 버튼 -->
    <Button
        android:id="@+id/cart_btn_order"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="주문하기"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/black"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
