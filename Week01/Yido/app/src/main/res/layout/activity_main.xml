<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/ic_back"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="26dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="150dp"
        android:gravity="center"
        android:text="오늘 하루는 어땠나요?"
        android:textColor="#000000"
        android:textSize="38sp"
        android:fontFamily="@font/gangwon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="감정우표를 선택해주세요"
        android:textColor="#000000"
        android:textSize="26sp"
        android:fontFamily="@font/gangwon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text1" />

    <TextView
        android:id="@+id/text_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="선택한 감정우표를 기반으로 맞춤형 질문이 배달됩니다"
        android:textColor="#000000"
        android:textSize="10sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text2" />

    <ImageView
        android:id="@+id/ic_face1"
        android:layout_width="44dp"
        android:layout_height="48.4dp"
        android:layout_marginTop="30dp"
        android:src="@drawable/ic_face1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text_description" />

    <TextView
        android:id="@+id/text_face1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="더없이 행복한 하루였어요"
        android:textColor="#000000"
        android:textSize="20sp"
        android:fontFamily="@font/gangwon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ic_face1" />

    <ImageView
        android:id="@+id/ic_face2"
        android:layout_width="44dp"
        android:layout_height="48.4dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/ic_face2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text_face1" />

    <TextView
        android:id="@+id/text_face2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="들뜨고 흥분돼요"
        android:textColor="#000000"
        android:textSize="20sp"
        android:fontFamily="@font/gangwon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ic_face2" />

    <ImageView
        android:id="@+id/ic_face3"
        android:layout_width="44dp"
        android:layout_height="48.4dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/ic_face3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text_face2" />

    <TextView
        android:id="@+id/text_face3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="평범한 하루였어요"
        android:textColor="#000000"
        android:textSize="20sp"
        android:fontFamily="@font/gangwon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ic_face3" />

    <ImageView
        android:id="@+id/ic_face4"
        android:layout_width="44dp"
        android:layout_height="48.4dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/ic_face4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text_face3" />

    <TextView
        android:id="@+id/text_face4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="생각이 많아지고 불안해요"
        android:textColor="#000000"
        android:textSize="20sp"
        android:fontFamily="@font/gangwon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ic_face4" />

    <ImageView
        android:id="@+id/ic_face5"
        android:layout_width="44dp"
        android:layout_height="48.4dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/ic_face5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text_face4" />

    <TextView
        android:id="@+id/text_face5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="부글부글 화가 나요"
        android:textColor="#000000"
        android:textSize="20sp"
        android:fontFamily="@font/gangwon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ic_face5" />

</androidx.constraintlayout.widget.ConstraintLayout>